<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige">
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="43dp"
        android:layout_height="45dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="60dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Назад"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:fontFamily="@font/zen_old_mincho_black"
        android:gravity="center"
        android:text="ИЗМЕНЕНИЕ\nЛИЧНЫХ ДАННЫХ"
        android:textAllCaps="true"
        android:textColor="@color/dark_brown"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <!-- Контейнер с полями ввода -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:background="@color/white"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/carlito_regular"
                android:text="Имя"
                android:textColor="@color/light_grey"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/underline_edit_text"
                android:fontFamily="@font/zen_old_mincho_regular"
                android:textColor="@color/dark_brown2"
                android:textSize="20sp"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/carlito_regular"
                android:text="Ник в приложении"
                android:textColor="@color/light_grey"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etNickname"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/underline_edit_text"
                android:fontFamily="@font/zen_old_mincho_regular"
                android:textColor="@color/dark_brown2"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/carlito_regular"
                android:text="E-mail"
                android:textColor="@color/light_grey"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginTop="10dp"
                android:inputType="textEmailAddress"
                android:background="@drawable/underline_edit_text"
                android:fontFamily="@font/zen_old_mincho_regular"
                android:textColor="@color/dark_brown2"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/carlito_regular"
                android:text="Дата рождения"
                android:textColor="@color/light_grey"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etBirthDate"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginTop="10dp"
                android:inputType="date"
                android:background="@drawable/underline_edit_text"
                android:fontFamily="@font/zen_old_mincho_regular"
                android:textColor="@color/dark_brown2"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/carlito_regular"
                android:text="Страна"
                android:textColor="@color/light_grey"
                android:textSize="14sp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_spinner_outlined"
                android:orientation="horizontal"
                android:paddingStart="15dp"
                tools:ignore="RtlSymmetry">

                <Spinner
                    android:id="@+id/spinnerCountry"
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:paddingVertical="5dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:spinnerMode="dropdown"
                    android:textColor="@color/dark_brown2"/>
                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginRight="5dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    android:contentDescription="Открыть список" />
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDone"
                android:layout_width="260dp"
                android:layout_height="45dp"
                android:layout_marginHorizontal="32dp"
                android:layout_marginTop="60dp"
                android:background="@drawable/shape_button_auth"
                android:fontFamily="@font/zen_old_mincho_semi_bold"
                android:text="ГОТОВО"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvDontSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="27dp"
                android:fontFamily="@font/zen_old_mincho_bold"
                android:gravity="center"
                android:text="НЕ СОХРАНЯТЬ"
                android:textColor="@color/brown"
                android:textSize="15sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>