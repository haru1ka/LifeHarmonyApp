<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <View
            android:id="@+id/handle"
            android:layout_width="70dp"
            android:layout_height="3dp"
            android:background="@color/dark_brown"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="ЧЕЛЛЕНДЖ МЕСЯЦА"
            android:textSize="15sp"
            android:textColor="#67370C"
            android:fontFamily="@font/zen_old_mincho_semi_bold"
            app:layout_constraintTop_toBottomOf="@id/handle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/ic_close"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivBanner"
            android:layout_width="match_parent"
            android:layout_height="216dp"
            android:layout_marginTop="30dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_meditation_banner"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <TextView
            android:id="@+id/tvSubTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="30 ДНЕЙ МЕДИТАЦИИ\nПЕРЕЗАГРУЗИ СВОЁ СОЗНАНИЕ ШАГ ЗА ШАГОМ!"
            android:textColor="@color/brown"
            android:fontFamily="@font/zen_old_mincho_semi_bold"
            app:layout_constraintTop_toBottomOf="@id/ivBanner" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="@string/challenge_text_no_bullets"
            android:textColor="@color/dark_brown"
            android:textSize="12sp"
            android:lineSpacingExtra="1dp"
            android:fontFamily="@font/carlito_regular"
            app:layout_constraintTop_toBottomOf="@id/tvSubTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="52dp"
            android:layout_marginTop="30dp"
            android:text="НАЧАТЬ ЧЕЛЛЕНДЖ"
            android:fontFamily="@font/zen_old_mincho_semi_bold"
            android:backgroundTint="@color/light_brown"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvDescription"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>